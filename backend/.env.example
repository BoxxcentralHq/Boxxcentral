# Server
PORT=4000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/boxxcentral

# Auth — use a long random string in production
JWT_SECRET=

# Flutterwave — empty keys = simulated-payment mode for development
FLW_SECRET_KEY=
FLW_SECRET_HASH=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Refresh tokens — must differ from JWT_SECRET
JWT_REFRESH_SECRET=

# ZeptoMail
ZEPTOMAIL_URL=https://api.zeptomail.com/
ZEPTOMAIL_TOKEN=
MAIL_FROM=
MAIL_FROM_NAME=BoxxCentral
MAIL_NOREPLY=
